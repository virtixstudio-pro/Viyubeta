<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_index"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#121212">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mon Profil"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="30dp"/>

    <TextView
        android:id="@+id/tv_settings_username"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@Username"
        android:textColor="#00E676"
        android:textSize="20sp"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tv_settings_email"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="email@example.com"
        android:textColor="#BBBBBB"
        android:textSize="16sp"
        android:layout_marginBottom="20dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#333333"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tv_settings_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Statut : En ligne"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tv_settings_bio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Bio : Passionné de code."
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:layout_marginBottom="30dp"/>

    <TextView
        android:id="@+id/tv_settings_joined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Rejoint le : --/--/----"
        android:textColor="#888888"
        android:textSize="14sp" />
</LinearLayout>
