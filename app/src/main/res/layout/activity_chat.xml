<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0A0A0A">
    <ListView android:id="@+id/lv_messages" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <EditText android:id="@+id/et_message" android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:hint="Message..."/>
        <Button android:id="@+id/btn_send" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Envoyer"/>
    </LinearLayout>
</LinearLayout>
