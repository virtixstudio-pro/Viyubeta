<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A"
    android:gravity="center"
    android:padding="32dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Inscription Viyu"
        android:textColor="#FFFFFF"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="40dp"/>

    <EditText
        android:id="@+id/et_register_email"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_input_rounded"
        android:hint="Email"
        android:textColorHint="#888888"
        android:textColor="#FFFFFF"
        android:paddingHorizontal="20dp"
        android:inputType="textEmailAddress"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/et_register_password"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_input_rounded"
        android:hint="Mot de passe (min 6 caractères)"
        android:textColorHint="#888888"
        android:textColor="#FFFFFF"
        android:paddingHorizontal="20dp"
        android:inputType="textPassword"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/et_register_password_confirm"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_input_rounded"
        android:hint="Confirme ton mot de passe"
        android:textColorHint="#888888"
        android:textColor="#FFFFFF"
        android:paddingHorizontal="20dp"
        android:inputType="textPassword"
        android:layout_marginBottom="12dp"/>

    <CheckBox
        android:id="@+id/cb_show_password_register"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Afficher les mots de passe"
        android:textColor="#888888"
        android:textSize="13sp"
        android:layout_gravity="start"
        android:layout_marginBottom="24dp"
        android:buttonTint="#FFFFFF"/>

    <Button
        android:id="@+id/btn_register_submit"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_button_rounded"
        android:text="Créer mon compte"
        android:textColor="#0A0A0A"
        android:textStyle="bold"
        android:textAllCaps="false"/>

    <TextView
        android:id="@+id/tv_go_to_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Déjà un compte ? Se connecter"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginTop="20dp"
        android:padding="8dp"/>

</LinearLayout>
