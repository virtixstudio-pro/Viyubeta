<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0A0A"
    android:padding="16dp">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">
        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Nouveau contact"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"/>
    </RelativeLayout>

    <!-- Recherche -->
    <EditText
        android:id="@+id/et_search_query"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="@drawable/bg_input_rounded"
        android:hint="Saisir l'identifiant exact"
        android:textColorHint="#666666"
        android:textColor="#FFFFFF"
        android:paddingStart="16dp"
        android:layout_marginBottom="24dp"
        android:inputType="text"/>

    <!-- Carte de résultat stylée -->
    <LinearLayout
        android:id="@+id/ll_result_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#121212"
        android:padding="16dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_result_username"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@Pseudo"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tv_result_email"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="email@domaine.com"
            android:textColor="#888888"
            android:textSize="14sp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="16dp"/>

        <Button
            android:id="@+id/btn_add_confirm"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:background="@drawable/bg_button_rounded"
            android:text="Ajouter"
            android:textColor="#0A0A0A"
            android:textStyle="bold"
            android:textAllCaps="false"/>
    </LinearLayout>

</LinearLayout>
